DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/payroll_db
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Social Security defaults (Thailand)
SS_RATE=0.05
SS_CAP_THB=750.0

# Work schedule defaults
WORK_START=08:00
WORK_END=17:00

# OT rounding policy: 30 or 60 (minutes)
OT_ROUND_MINUTES=30
